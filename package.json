{
  "name": "nuxtcommerce",
  "version": "3.1.24",
  "private": true,
  "author": "zackha",
  "description": "Nuxt storefront backed by Laravel and MySQL",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "dev:ssl": "nuxt dev --https --ssl-cert localhost.pem --ssl-key localhost-key.pem",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "build": "nuxt build",
    "deploy:pages": "bumpp && pnpm build && wrangler pages deploy dist --project-name commerce --branch master"
  },
  "dependencies": {
    "@gradio/client": "^1.7.0",
    "@nuxt/image": "^1.11.0",
    "@nuxt/ui": "^2.22.3",
    "@nuxthub/core": "0.10.6",
    "notivue": "^2.4.5",
    "nuxt": "^4.4.2",
    "swiper": "^12.1.2",
    "vue": "latest"
  },
  "devDependencies": {
    "@iconify-json/iconamoon": "^1.2.2",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@types/node": "^25.6.0",
    "@vite-pwa/nuxt": "^1.0.4",
    "@vueuse/core": "^13.9.0",
    "@vueuse/nuxt": "^13.9.0",
    "vue-tsc": "^3.2.7",
    "wrangler": "^4.76.0"
  },
  "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937"
}
